  "1.11.2" : 
  {
    "1.0.16" : "-zombie villager graphics can now be disabled separately. they're no longer bound to regular zombies.\n",
    "1.0.15" : "-fixed cute zombie villagers spamming the log with errors.\n"
  },

  "1.11.0" : 
  {
    "1.0.14" : "-fixed cute villagers not spawning from an egg when separate entities is active.\n"
